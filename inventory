---
# Ansible inventory file for deployment targets
# Stage 4: Configuration Management Server - manages App Server remotely

[appservers]
tomcat-server ansible_host=<APP_SERVER_IP> ansible_user=ec2-user ansible_ssh_private_key_file=~/.ssh/key.pem

[all:vars]
ansible_ssh_common_args='-o StrictHostKeyChecking=no'
